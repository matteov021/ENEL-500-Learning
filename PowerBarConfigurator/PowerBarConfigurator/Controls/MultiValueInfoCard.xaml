<UserControl x:Class="PowerBarConfigurator.Controls.MultiValueInfoCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Height="110" Width="220">

    <Grid>
        <!-- Existing Card -->
        <Border Style="{StaticResource ContentCardStyle}" 
                Padding="12">
            <StackPanel>

                <!-- Header -->
                <StackPanel Orientation="Horizontal" 
                            Margin="0,0,0,8">
                    <Ellipse Width="12" 
                             Height="12"
                             Margin="0,0,0,-2"
                             Fill="{Binding StatusColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                               FontSize="13" 
                               Foreground="{DynamicResource PrimaryTextBrush}" 
                               Margin="6,0,0,0"/>
                </StackPanel>

                <!-- Values Grid -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <!-- Amperage -->
                    <TextBlock Text="Amperage Limit:"
                               Grid.Row="0"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="{Binding Amperage, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Grid.Row="0"
                               HorizontalAlignment="Right"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <!-- Voltage -->
                    <TextBlock Text="Voltage Limit:"
                               Grid.Row="1"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="{Binding Voltage, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Grid.Row="1"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Right"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <!-- Wattage -->
                    <TextBlock Text="Wattage Limit:"
                               Grid.Row="2"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="{Binding Wattage, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Grid.Row="2"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Right"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Power Button -->
        <Button Width="40"
                Height="24"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,8,0"
                Style="{StaticResource RoundedButtonStyle}"
                Click="PowerButton_Click">
            <md:PackIcon Kind="Power" 
                         Width="16" 
                         Height="16" 
                         VerticalAlignment="Center" 
                         HorizontalAlignment="Center"/>
        </Button>
    </Grid>
</UserControl>