<UserControl x:Class="PowerBarConfigurator.Controls.InfoCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="120" Width="220">

    <!-- Dependency Properties -->
    <Border Style="{StaticResource ContentCardStyle}" Padding="12">
        <StackPanel>
            <StackPanel Orientation="Horizontal" 
                        Margin="0,0,0,6">

                <!-- Status Indicator -->
                <Ellipse Width="12" 
                         Height="12" 
                         Margin="0,0,0,-2"
                         Fill="{Binding StatusColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                <!-- Title Text -->
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="13" 
                           Foreground="{DynamicResource PrimaryTextBrush}" 
                           Margin="6,0,0,0"/>
            </StackPanel>

            <!-- Value Text -->
            <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="24"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>