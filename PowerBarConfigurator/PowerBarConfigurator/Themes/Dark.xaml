<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Colors -->
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#1F232A"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2A2F38"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#252A33"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="White"/>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="White"/>

    <!-- Navigation -->
    <SolidColorBrush x:Key="NavButtonHoverBrush" Color="#323844"/>
    <SolidColorBrush x:Key="NavButtonPressedBrush" Color="#3C4452"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#3A3F4A"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#4A5160"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#5A6274"/>

    <!-- Hyperlink -->
    <SolidColorBrush x:Key="HyperlinkBrush" Color="#7AA2F7"/>

</ResourceDictionary>