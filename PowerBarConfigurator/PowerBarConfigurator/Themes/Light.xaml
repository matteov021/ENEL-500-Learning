<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors -->
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1F2933"/>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="White"/>

    <!-- Navigation -->
    <SolidColorBrush x:Key="NavButtonHoverBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="NavButtonPressedBrush" Color="#D1D5DB"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#374151"/>

    <!-- Hyperlink -->
    <SolidColorBrush x:Key="HyperlinkBrush" Color="#2563EB"/>

</ResourceDictionary>