<Window x:Class="PowerBarConfigurator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="PowerBarConfigurator" 
        Height="800" 
        Width="1280" 
        WindowStartupLocation="CenterScreen">

    <!-- Main Layout Grid -->
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" 
                              Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border x:Name="SidebarContainer"
                Grid.Column="0"
                Margin="24,24,0,24"
                Padding="12"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1"
                                  Opacity="0.12"/>
            </Border.Effect>

            <!-- ScrollViewer -->
            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">

                <!-- Navigation Buttons -->
                <StackPanel>

                    <!-- Toggle Sidebar Button -->
                    <Button Tag="ToggleSidebar"
                            Style="{StaticResource NavButtonStyle}"
                            Width="56"
                            Height="50"
                            HorizontalAlignment="Left"
                            Click="ToggleSidebar_Click">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Menu" 
                                         Width="26" 
                                         Height="26" 
                                         Margin="4,0,12,0"
                                         VerticalAlignment="Center" 
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Button>

                    <!-- Home Button -->
                    <Button Tag="Home"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Nav_Click">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Home" 
                                         Width="26" 
                                         Height="26" 
                                         Margin="4,0,12,0"
                                         VerticalAlignment="Center" 
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Home" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Graphs Button -->
                    <Button Tag="Graphs"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Nav_Click">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ChartLine" 
                                         Width="26" 
                                         Height="26" 
                                         Margin="4,0,12,0"
                                         VerticalAlignment="Center" 
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Graphs" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Data Logging Button -->
                    <Button Tag="DataLogging"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Nav_Click">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="DatabaseExport" 
                                         Width="26" 
                                         Height="26" 
                                         Margin="4,0,12,0"
                                         VerticalAlignment="Center" 
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Data Logging" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Configuration Button -->
                    <Button Tag="Configuration"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Nav_Click">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Cog" 
                                         Width="26" 
                                         Height="26" 
                                         Margin="4,0,12,0"
                                         VerticalAlignment="Center" 
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Configuration" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Settings Button -->
                    <Button Tag="Settings"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Nav_Click">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Tune" 
                                         Width="26" 
                                         Height="26" 
                                         Margin="4,0,12,0"
                                         VerticalAlignment="Center" 
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Settings" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- About Button -->
                    <Button Tag="About"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Nav_Click">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Information" 
                                         Width="26" 
                                         Height="26" 
                                         Margin="4,0,12,0"
                                         VerticalAlignment="Center" 
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="About" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Content Area -->
        <ContentControl x:Name="ContentHost" 
                        Grid.Column="1" 
                        Background="{DynamicResource CardBackgroundBrush}"/>
    </Grid>
</Window>