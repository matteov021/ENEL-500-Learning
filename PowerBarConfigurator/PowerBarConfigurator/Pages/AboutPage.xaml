<UserControl x:Class="PowerBarConfigurator.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource PageBackgroundBrush}">

    <!-- Main Container -->
    <Border Style="{StaticResource ContentCardStyle}"
                Background="{DynamicResource CardBackgroundBrush}"
                Padding="24"
                Margin="24">

        <!-- ScrollViewer -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">

            <!-- Content StackPanel -->
            <StackPanel>

                <!-- Title -->
                <TextBlock Text="About"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,0,0,24"/>

                <!-- Application Description -->
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="15"
                           Margin="0,0,0,20">
                    This application is a desktop utility used to configure and monitor a smart power distribution unit.
                    This software allows users to monitor outlet power usage in real time, visualize current and power draw through graphs, configure outlet limits, log electrical data, and update firmware on the connected device.
                </TextBlock>

                <!-- Divider -->
                <Border Height="1"
                        Background="{DynamicResource PrimaryTextBrush}"
                        Margin="0,10,0,20"/>

                <!-- Version -->
                <TextBlock Text="Application Version"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="16"/>
                <TextBlock Text="v1.0.0"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,4,0,20"/>

                <!-- Credits -->
                <TextBlock Text="Credits"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="16"/>
                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14"
                           Margin="0,4,0,20">
                    Developed by: Aviaee
                </TextBlock>

                <!-- Links -->
                <TextBlock Text="Links"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="16"/>

                <!-- Github link is represented as a horizontal StackPanel with an icon and a Hyperlink -->
                <StackPanel Orientation="Horizontal" 
                            Margin="0,4">
                    <md:PackIcon Kind="Github" 
                                 Width="18" 
                                 Height="18" 
                                 Margin="0,0,8,0" 
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Hyperlink NavigateUri="https://github.com/Restoration-Hub/power-bar-software" 
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            GitHub Repository
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Website link is represented as a horizontal StackPanel with an icon and a Hyperlink -->
                <StackPanel Orientation="Horizontal" 
                            Margin="0,4">
                    <md:PackIcon Kind="Web" 
                                 Width="18" 
                                 Height="18" 
                                 Margin="0,0,8,0" 
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Hyperlink NavigateUri="https://www.aviaee.com/" 
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            Project Website
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Linkedin link is represented as a horizontal StackPanel with an icon and a Hyperlink -->
                <StackPanel Orientation="Horizontal" 
                            Margin="0,4">
                    <md:PackIcon Kind="Linkedin" 
                                 Width="18" 
                                 Height="18" 
                                 Margin="0,0,8,0" 
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Hyperlink NavigateUri="https://www.linkedin.com/company/aviaee/" 
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            LinkedIn
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1"
                        Background="{DynamicResource PrimaryTextBrush}"
                        Margin="0,20,0,20"/>

                <!-- License & Third-party libraries -->
                <TextBlock Text="License &amp; Third-Party Libraries"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="16"/>

                <!-- Application License -->
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14"
                           Margin="0,4,0,10">
                    This software is released under the MIT License.
                </TextBlock>

                <!-- Third-party libraries -->
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14"
                           Margin="0,4,0,10">
                    SharpCubeProgrammer – MS-RL, SLA0048, Segger JLink License<LineBreak/>
                    <Hyperlink NavigateUri="https://github.com/K-Society/KSociety.SharpCubeProgrammer" 
                               RequestNavigate="Hyperlink_RequestNavigate">
                        https://github.com/K-Society/KSociety.SharpCubeProgrammer
                    </Hyperlink>
                </TextBlock>

                <!-- Livecharts Hyperlink and License -->
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14"
                           Margin="0,4,0,10">
                    LiveChartsCore / LiveCharts2 – MIT License<LineBreak/>
                    <Hyperlink NavigateUri="https://github.com/Live-Charts/LiveCharts2" 
                               RequestNavigate="Hyperlink_RequestNavigate">
                        https://github.com/Live-Charts/LiveCharts2
                    </Hyperlink>
                </TextBlock>

                <!-- MaterialDesignTheme Hyperlink and License -->
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14"
                           Margin="0,4,0,10">
                    MaterialDesignThemes – MIT License<LineBreak/>
                    <Hyperlink NavigateUri="https://github.com/MaterialDesignInXAML/MaterialDesignInXamlToolkit" 
                               RequestNavigate="Hyperlink_RequestNavigate">
                        https://github.com/MaterialDesignInXAML/MaterialDesignInXamlToolkit
                    </Hyperlink>
                </TextBlock>

                <!-- NModBus Hyperlink and License -->
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14"
                           Margin="0,4,0,10">
                    NModbus – MIT License<LineBreak/>
                    <Hyperlink NavigateUri="https://github.com/NModbus/NModbus" 
                               RequestNavigate="Hyperlink_RequestNavigate">
                        https://github.com/NModbus/NModbus
                    </Hyperlink>
                </TextBlock>

                <!-- DotNet Hyperlink and License -->
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14"
                           Margin="0,4,0,10">
                    System.IO.Ports – included in .NET runtime<LineBreak/>
                    <Hyperlink NavigateUri="https://dotnet.microsoft.com/en-us/" 
                               RequestNavigate="Hyperlink_RequestNavigate">
                        https://dotnet.microsoft.com/en-us/
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>