<UserControl x:Class="PowerBarConfigurator.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:PowerBarConfigurator.Controls"
             Background="{DynamicResource PageBackgroundBrush}">

    <!-- Main Container -->
    <Border Style="{StaticResource ContentCardStyle}"
            Background="{DynamicResource CardBackgroundBrush}"
            Padding="24"
            Margin="24">

        <Grid>
            <!-- Layout Rows -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                           Text="Overview"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Margin="0,0,0,24"/>

            <!-- Main Content Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- InfoCards + Buttons -->
                <StackPanel Grid.Column="0"
                                Orientation="Vertical"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Margin="0,0,24,0">

                    <controls:InfoCard x:Name="StatusCard"
                                           Title="Global Outlet Status"
                                           Value="Off"
                                           StatusColor="Red"
                                           Margin="0,0,0,16"/>

                    <controls:InfoCard x:Name="ConnectionCard"
                                           Title="Connection"
                                           Value="Disconnected"
                                           StatusColor="Red"
                                           Margin="0,0,0,16"/>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Stretch">

                        <!-- Connect Button -->
                        <Button x:Name="ConnectButton"
                                    Width="220"
                                    Height="73"
                                    Margin="0,0,0,12"
                                    Style="{StaticResource RoundedButtonStyle}"
                                    Click="ConnectButton_Click">
                            <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Center">
                                <md:PackIcon Kind="Plug" 
                                                 Width="18" 
                                                 Height="18" 
                                                 Margin="0,0,8,-2"
                                                 VerticalAlignment="Center"/>
                                <TextBlock x:Name="ConnectButtonText"
                                               Text="Connect" 
                                               VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Power Button -->
                        <Button Width="220"
                                    Height="73"
                                    Margin="0,0,0,12"
                                    Style="{StaticResource RoundedButtonStyle}"
                                    Click="PowerButton_Click">
                            <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Center">
                                <md:PackIcon Kind="PowerPlug" 
                                                 Width="18" 
                                                 Height="18" 
                                                 Margin="0,0,8,-2"
                                                 VerticalAlignment="Center"/>
                                <TextBlock Text="Toggle All Outlets" 
                                               VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Clear Log Button -->
                        <Button Width="220"
                                    Height="73"
                                    Margin="0,0,0,12"
                                    Style="{StaticResource RoundedButtonStyle}"
                                    Click="ClearLogButton_Click">
                            <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Center">
                                <md:PackIcon Kind="Delete" 
                                                 Width="18" 
                                                 Height="18" 
                                                 Margin="0,0,8,-2"
                                                 VerticalAlignment="Center"/>
                                <TextBlock Text="Clear Log" 
                                               VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Export CSV Button -->
                        <Button Width="220"
                                    Height="73"
                                    Style="{StaticResource RoundedButtonStyle}"
                                    Click="ExportLogButton_Click">
                            <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Center">
                                <md:PackIcon Kind="FileCsv" 
                                                 Width="18" 
                                                 Height="18" 
                                                 Margin="0,0,8,-2"
                                                 VerticalAlignment="Center"/>
                                <TextBlock Text="Export CSV" 
                                               VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- System Activity Panel -->
                <Border Grid.Column="1"
                            Padding="20"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            CornerRadius="12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10"
                                              ShadowDepth="1"
                                              Opacity="0.1"/>
                    </Border.Effect>

                    <!-- Activity Content -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <TextBlock Grid.Row="0"
                                       Text="System Activity"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                        <!-- Activity Log -->
                        <ListBox Grid.Row="1"
                                     x:Name="ActivityList"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     FontSize="13"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                        <!-- Divider -->
                        <Border Grid.Row="2"
                                    Height="1"
                                    Margin="0,16,0,8"
                                    Background="{DynamicResource PrimaryTextBrush}"/>

                        <!-- Placeholder -->
                        <TextBlock Grid.Row="3"
                                       Text="Logs will appear here once the microcontroller is connected."
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>