<UserControl x:Class="PowerBarConfigurator.Pages.ConfigurationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:PowerBarConfigurator.Controls"
             xmlns:properties="clr-namespace:PowerBarConfigurator.Properties"
             Background="{DynamicResource PageBackgroundBrush}">

    <!-- Main Container -->
    <Border Style="{StaticResource ContentCardStyle}"
            Background="{DynamicResource CardBackgroundBrush}"
            Padding="24"
            Margin="24">

        <!-- ScrollViewer -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">

            <!-- Layout Grid -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0"
                           Text="Configuration"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Margin="0,0,0,24"/>

                <!-- Info Cards -->
                <WrapPanel x:Name="InfoCardsPanel" 
                           Grid.Row="1">

                    <controls:MultiValueInfoCard Title="Outlet 1"
                                                 RegisterIndex="0"
                                                 Margin="0,0,12,12"/>

                    <controls:MultiValueInfoCard Title="Outlet 2"
                                                 RegisterIndex="1"
                                                 Margin="0,0,12,12"/>

                    <controls:MultiValueInfoCard Title="Outlet 3"
                                                 RegisterIndex="2"
                                                 Margin="0,0,12,12"/>

                    <controls:MultiValueInfoCard Title="Outlet 4"
                                                 RegisterIndex="3"
                                                 Margin="0,0,12,12"/>

                    <controls:MultiValueInfoCard Title="Outlet 5"
                                                 RegisterIndex="4"
                                                 Margin="0,0,12,12"/>

                    <controls:MultiValueInfoCard Title="Outlet 6"
                                                 RegisterIndex="5"
                                                 Margin="0,0,12,12"/>

                    <controls:MultiValueInfoCard Title="Outlet 7"
                                                 RegisterIndex="6"
                                                 Margin="0,0,12,12"/>

                    <controls:MultiValueInfoCard Title="Outlet 8"
                                                 RegisterIndex="7"
                                                 Margin="0,0,12,12"/>

                    <controls:MultiValueInfoCard Title="Outlet 9"
                                                 RegisterIndex="8"
                                                 Margin="0,0,12,12"/>

                    <controls:MultiValueInfoCard Title="Outlet 10"
                                                 RegisterIndex="9"
                                                 Margin="0,0,12,12"/>
                </WrapPanel>

                <!-- Configuration Form -->
                <Border Grid.Row="2"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        CornerRadius="8"
                        Padding="20">

                    <!-- Form Grid -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Form Columns -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Form Fields -->
                        <StackPanel Orientation="Horizontal" 
                                    Grid.Row="0" 
                                    Grid.Column="0" 
                                    VerticalAlignment="Center">
                            <md:PackIcon Kind="PowerPlug" 
                                         Width="18" 
                                         Height="18" 
                                         Margin="0,0,10,0" 
                                         VerticalAlignment="Center" 
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Select Outlet" 
                                       VerticalAlignment="Center" 
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>

                        <!-- Outlet Selector ComboBox -->
                        <ComboBox x:Name="OutletSelector"
                                  Style="{StaticResource DropDownStyle}"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  Width="180"
                                  HorizontalAlignment="Left">

                            <!-- ComboBox Items -->
                            <ComboBoxItem Content="All Outlets"/>
                            <ComboBoxItem Content="Outlet 1"/>
                            <ComboBoxItem Content="Outlet 2"/>
                            <ComboBoxItem Content="Outlet 3"/>
                            <ComboBoxItem Content="Outlet 4"/>
                            <ComboBoxItem Content="Outlet 5"/>
                            <ComboBoxItem Content="Outlet 6"/>
                            <ComboBoxItem Content="Outlet 7"/>
                            <ComboBoxItem Content="Outlet 8"/>
                            <ComboBoxItem Content="Outlet 9"/>
                            <ComboBoxItem Content="Outlet 10"/>
                        </ComboBox>

                        <!-- Limit Type -->
                        <StackPanel Orientation="Horizontal" 
                                    Grid.Row="1" 
                                    Grid.Column="0" 
                                    VerticalAlignment="Center" 
                                    Margin="0,12,0,0">
                            <md:PackIcon Kind="Speedometer" 
                                         Width="18" 
                                         Height="18" 
                                         Margin="0,0,10,0" 
                                         VerticalAlignment="Center" 
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Limit Type" 
                                       VerticalAlignment="Center" 
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>

                        <!-- Limit Type ComboBox -->
                        <ComboBox x:Name="LimitTypeSelector"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Width="180"
                                  Margin="0,12,0,0"
                                  HorizontalAlignment="Left"
                                  Style="{StaticResource DropDownStyle}">

                            <!-- ComboBox Items -->
                            <ComboBoxItem Content="Amperage"/>
                            <ComboBoxItem Content="Wattage"/>
                        </ComboBox>

                        <!-- Limit Value -->
                        <StackPanel Orientation="Horizontal" 
                                    Grid.Row="2" 
                                    Grid.Column="0" 
                                    VerticalAlignment="Center" 
                                    Margin="0,12,0,0">
                            <md:PackIcon Kind="Numeric" 
                                         Width="18" 
                                         Height="18" 
                                         Margin="0,2,10,0" 
                                         VerticalAlignment="Center" 
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Limit Value" 
                                       VerticalAlignment="Center" 
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>

                        <!-- Limit Value TextBox -->
                        <TextBox x:Name="LimitValueBox"
                                 Grid.Row="2"
                                 Grid.Column="1"
                                 Width="180"
                                 Height="25"
                                 Margin="0,12,0,0"
                                 HorizontalAlignment="Left"/>

                        <!-- Save Button -->
                        <Button Grid.Row="4"
                                Grid.Column="1"
                                Width="185"
                                Height="35"
                                Margin="-2,10,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource RoundedButtonStyle}"
                                Click="SaveConfig_Click">
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center">
                                <md:PackIcon Kind="ContentSave" 
                                             Width="18" 
                                             Height="18" 
                                             Margin="0,0,6,0" 
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="Save Configuration" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>