<UserControl x:Class="PowerBarConfigurator.Pages.DataLoggingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource PageBackgroundBrush}">

    <!-- Main Container -->
    <Border Style="{StaticResource ContentCardStyle}"
            Background="{DynamicResource CardBackgroundBrush}"
            Padding="24"
            Margin="24">

        <!-- Layout Grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page Title -->
            <TextBlock Grid.Row="0"
                           Text="Data Logging"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Margin="0,0,0,24"/>

            <!-- Controls Row -->
            <Grid Grid.Row="1" Margin="-4,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Outlet Selection -->
                <StackPanel Orientation="Horizontal" 
                                VerticalAlignment="Center">

                    <!-- Label for outlet selection -->
                    <TextBlock Text="Outlet:" 
                                   Foreground="{DynamicResource PrimaryTextBrush}" 
                                   VerticalAlignment="Center"
                                   Margin="6,0,6,0"/>

                    <!-- Dropdown for outlet selection -->
                    <ComboBox x:Name="OutletComboBox" 
                                  Style="{StaticResource DropDownStyle}" 
                                  Width="140">
                        <ComboBoxItem Content="Outlet 1"/>
                        <ComboBoxItem Content="Outlet 2"/>
                        <ComboBoxItem Content="Outlet 3"/>
                        <ComboBoxItem Content="Outlet 4"/>
                        <ComboBoxItem Content="Outlet 5"/>
                        <ComboBoxItem Content="Outlet 6"/>
                        <ComboBoxItem Content="Outlet 7"/>
                        <ComboBoxItem Content="Outlet 8"/>
                        <ComboBoxItem Content="Outlet 9"/>
                        <ComboBoxItem Content="Outlet 10"/>
                    </ComboBox>
                </StackPanel>

                <!-- Start Logging Button -->
                <Button x:Name="StartLoggingButton"
                            Grid.Column="1" 
                            Margin="12,0,0,0" 
                            Width="130"
                            Style="{StaticResource RoundedButtonStyle}" 
                            Click="StartLogging_Click">
                    <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                        <md:PackIcon Kind="PlayCircle" 
                                         Width="16" 
                                         Height="16" 
                                         Margin="0,0,6,-2" 
                                         VerticalAlignment="Center"/>
                        <TextBlock Text="Start Logging" 
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Stop Logging Button -->
                <Button x:Name="StopLoggingButton"
                            Grid.Column="2"  
                            HorizontalAlignment="Left" 
                            Width="130"
                            Margin="12,0,12,0"
                            Style="{StaticResource RoundedButtonStyle}" 
                            IsEnabled="False"
                            Click="StopLogging_Click">
                    <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                        <md:PackIcon Kind="StopCircle" 
                                         Width="16" 
                                         Height="16" 
                                         Margin="0,0,6,-2" 
                                         VerticalAlignment="Center"/>
                        <TextBlock Text="Stop Logging" 
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Clear Log Button -->
                <Button Grid.Column="3" 
                            Width="120" 
                            Margin="0,0,12,0"
                            Style="{StaticResource RoundedButtonStyle}" 
                            Click="ClearLog_Click">
                    <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                        <md:PackIcon Kind="Delete" 
                                         Width="16" 
                                         Height="16" 
                                         Margin="0,0,6,-2" 
                                         VerticalAlignment="Center"/>
                        <TextBlock Text="Clear Log" 
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Export CSV Button -->
                <Button Grid.Column="4" 
                            Width="120" 
                            Style="{StaticResource RoundedButtonStyle}" 
                            Click="ExportCsv_Click">
                    <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                        <md:PackIcon Kind="FileCsv" 
                                         Width="16" 
                                         Height="16" 
                                         Margin="0,0,6,-2" 
                                         VerticalAlignment="Center"/>
                        <TextBlock Text="Export CSV" 
                                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Logging Panel -->
            <Border Grid.Row="2"
                        Padding="20"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        CornerRadius="12"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">

                <!-- Subtle shadow effect for depth -->
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                          ShadowDepth="1"
                                          Opacity="0.1"/>
                </Border.Effect>

                <!-- Log Stream Layout -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0"
                                   Text="Data Log"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                    <!-- Log Stream -->
                    <ListBox Grid.Row="1"
                                 x:Name="LoggingList"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 FontSize="13"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                    <!-- Divider -->
                    <Border Grid.Row="2"
                                Height="1"
                                Margin="0,16,0,8"
                                Background="{DynamicResource PrimaryTextBrush}"/>

                    <!-- Footer -->
                    <TextBlock Grid.Row="3"
                                   Text="Log samples will appear here while data logging is active."
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <!-- Note about idle readings -->
                    <TextBlock Grid.Row="4"
                                           Text="Note: Due to electrical noise in the regulator, readings at idle may be inaccurate. Measurements become more reliable when a load is present."
                                           FontSize="12"
                                           FontStyle="Italic"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>