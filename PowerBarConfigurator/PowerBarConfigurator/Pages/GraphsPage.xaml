<UserControl x:Class="PowerBarConfigurator.Pages.GraphsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:PowerBarConfigurator.Controls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{DynamicResource PageBackgroundBrush}">

    <!-- Main Container -->
    <Border Style="{StaticResource ContentCardStyle}"
            Background="{DynamicResource CardBackgroundBrush}"
            Padding="24"
            Margin="24">

        <!-- ScrollViewer -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <!-- Layout Grid -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0"
                           Text="Graphs"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Margin="0,0,0,24"/>

                <!-- Info Cards + Controls -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Info Cards -->
                    <StackPanel Orientation="Horizontal"
                                Grid.Column="0"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left">

                        <!-- Current Card -->
                        <controls:InfoCard x:Name="CurrentCard"
                                           Title="Amperage (RMS)"
                                           Value="- A"
                                           StatusColor="Orange"
                                           Margin="0,0,5,0"/>

                        <!-- Voltage Card -->
                        <controls:InfoCard x:Name="VoltageCard"
                                           Title="Voltage"
                                           Value="- V"
                                           StatusColor="MediumPurple"
                                           Margin="5,0,5,0"/>

                        <!-- Power Card -->
                        <controls:InfoCard x:Name="PowerCard"
                                           Title="Power Draw"
                                           Value="- W"
                                           StatusColor="DarkCyan"
                                           Margin="5,0,20,0"/>
                    </StackPanel>

                    <!-- Outlet Controls -->
                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                VerticalAlignment="Bottom"
                                Margin="60,0,0,0">

                        <!-- Max/Min Info -->
                        <TextBlock Text="ADC Values (0 - 4095)"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="14"
                                   Margin="0,0,0,5"/>

                        <!-- Max/Min Info -->
                        <TextBlock x:Name="BufferMinMaxText"
                                   Text="Min: - , Max: -"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="14"
                                   Margin="0,0,0,5"/>

                        <!-- Graph Selection -->
                        <StackPanel Orientation="Horizontal" 
                                    Margin="0,0,0,10">
                            <TextBlock Text="Graph:"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       FontSize="14"/>

                            <!-- Graph ComboBox -->
                            <ComboBox x:Name="GraphComboBox"
                                      Style="{StaticResource DropDownStyle}"
                                      Width="120">
                                <ComboBoxItem Content="Current"/>
                                <ComboBoxItem Content="Wattage"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Outlet Selection -->
                        <StackPanel Orientation="Horizontal" 
                                    Margin="0,0,0,10">
                            <TextBlock Text="Outlet:"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0"
                                       FontSize="14"/>
                            
                            <!-- Outlet ComboBox -->
                            <ComboBox x:Name="OutletComboBox"
                                      Style="{StaticResource DropDownStyle}"
                                      Width="120">
                                <ComboBoxItem Content="Outlet 1"/>
                                <ComboBoxItem Content="Outlet 2"/>
                                <ComboBoxItem Content="Outlet 3"/>
                                <ComboBoxItem Content="Outlet 4"/>
                                <ComboBoxItem Content="Outlet 5"/>
                                <ComboBoxItem Content="Outlet 6"/>
                                <ComboBoxItem Content="Outlet 7"/>
                                <ComboBoxItem Content="Outlet 8"/>
                                <ComboBoxItem Content="Outlet 9"/>
                                <ComboBoxItem Content="Outlet 10"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Apply Button -->
                        <Button Width="170"
                                Height="36"
                                HorizontalAlignment="Left" 
                                Style="{StaticResource RoundedButtonStyle}"
                                Click="ApplyOutlet_Click">
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center">
                                <md:PackIcon Kind="Refresh" 
                                             Width="16" 
                                             Height="16" 
                                             Margin="0,0,6,-2" 
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="Apply / Refresh" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Graph Area -->
                <Border Grid.Row="2"
                    Style="{StaticResource ContentCardStyle}"
                    Margin="0,10,0,0">

                    <!-- Placeholder for LiveCharts Graph -->
                    <lvc:CartesianChart x:Name="CurrentChart"/>

                </Border>

                <!-- Note about idle readings -->
                <TextBlock Grid.Row="3"
                           Text="Note: Due to electrical noise in the regulator, readings at idle may be inaccurate. Measurements become more reliable when a load is present."
                           FontSize="12"
                           FontStyle="Italic"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="4,8,4,0"
                           TextWrapping="Wrap"/>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>