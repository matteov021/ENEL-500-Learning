<UserControl x:Class="PowerBarConfigurator.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource PageBackgroundBrush}">

    <!-- Main Container -->
    <Border Style="{StaticResource ContentCardStyle}"
            Background="{DynamicResource CardBackgroundBrush}"
            Padding="24" 
            Margin="24">

        <!-- ScrollViewer -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">

            <!-- Layout StackPanel -->
            <StackPanel>
                <TextBlock Text="Settings" 
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="30" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,24"/>

                <!-- Voltage Section -->
                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Center" 
                            Margin="0,0,0,5">
                    <md:PackIcon Kind="Flash" 
                                 Width="18" 
                                 Height="18"
                                 Margin="0,0,4,0"
                                 VerticalAlignment="Bottom"
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="Voltage" 
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Voltage Selection -->
                <ComboBox x:Name="VoltageSelector"
                          Style="{StaticResource DropDownStyle}"
                          SelectionChanged="VoltageSelector_SelectionChanged"
                          Width="150" 
                          HorizontalAlignment="Left" 
                          Margin="0,5,0,15">
                    <ComboBoxItem Content="120 V"/>
                    <ComboBoxItem Content="240 V"/>
                </ComboBox>

                <!-- Theme Section -->
                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Center" 
                            Margin="0,0,0,5">
                    <md:PackIcon Kind="Palette" 
                                 Width="18" 
                                 Height="18"
                                 Margin="0,0,4,0"
                                 VerticalAlignment="Bottom"
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="Theme" 
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Theme Selection -->
                <ComboBox x:Name="ThemeSelector"
                          Style="{StaticResource DropDownStyle}"
                          SelectionChanged="ThemeSelector_SelectionChanged"
                          Width="150" 
                          HorizontalAlignment="Left" 
                          Margin="0,5,0,20">
                    <ComboBoxItem Content="Dark"/>
                    <ComboBoxItem Content="Light"/>
                </ComboBox>

                <!-- Divider -->
                <Border Height="1"
                    Background="{DynamicResource PrimaryTextBrush}"
                    Margin="0,20"/>

                <!-- Firmware Section -->
                <TextBlock Text="Firmware"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <!-- Firmware Version Display -->
                <TextBlock x:Name="FirmwareVersionText"
                           Text="Current Version: - (Device is not connected.) "
                           Foreground="{DynamicResource PrimaryTextBrush}" 
                           FontSize="14" 
                           Margin="0,0,0,12"/>

                <!-- Firmware Update Instructions Card -->
                <Border Background="{DynamicResource CardBackgroundBrush}"
                        Padding="12"
                        Margin="0,0,0,12"
                        CornerRadius="6"
                        BorderBrush="{DynamicResource PrimaryTextBrush}"
                        BorderThickness="1"
                        HorizontalAlignment="Left"
                        MaxWidth="480">

                    <!-- Instructions StackPanel -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" 
                                    Margin="0,0,0,6">
                            <md:PackIcon Kind="InformationOutline"
                                         Width="16"
                                         Height="16"
                                         Margin="-4,0,6,0"
                                         Foreground="{DynamicResource PrimaryTextBrush}"/>

                            <!-- Instructions Header -->
                            <TextBlock Text="Firmware Update Steps:"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>

                        <!-- Step-by-step Instructions -->
                        <TextBlock Text="1. Select a firmware (.bin) file."
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="13"
                                   Margin="0,2"/>

                        <TextBlock Text="2. Press and hold the FIRST button on the device."
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="13"
                                   Margin="0,2"/>

                        <TextBlock Text="3. While holding, click 'Enter DFU Mode' and wait ~5 seconds before releasing."
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="13"
                                   Margin="0,2"/>

                        <TextBlock Text="4. Click 'Flash Firmware' and do not disconnect power."
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="13"
                                   Margin="0,2"/>

                        <TextBlock Text="5. Power cycle the device after completion."
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="13"
                                   Margin="0,2"/>
                    </StackPanel>
                </Border>

                <!-- Firmware Selection Row -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Select Firmware Button -->
                    <Button Width="150"
                            Height="36"
                            Margin="0,0,10,0"
                            Style="{StaticResource RoundedButtonStyle}"
                            Click="SelectFirmware_Click">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                            <md:PackIcon Kind="FolderOpen" 
                                         Width="18" 
                                         Height="18" 
                                         Margin="-2,0,6,0"/>
                            <TextBlock Text="Select Firmware" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Selected Firmware Path -->
                    <TextBlock Grid.Column="1"
                               x:Name="FirmwarePathText"
                               Text="No file selected"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>

                <!-- Enter DFU Mode Button -->
                <Button x:Name="EnterDfuButton"
                        Width="150"
                        Height="36"
                        Margin="0,5,0,10"
                        HorizontalAlignment="Left"
                        Style="{StaticResource RoundedButtonStyle}"
                        IsEnabled="False"
                        Click="EnterDfu_Click">
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <md:PackIcon Kind="Usb" 
                                     Width="18" 
                                     Height="18" 
                                     Margin="0,0,6,0"/>
                        <TextBlock Text="Enter DFU Mode" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Flash Button -->
                <Button x:Name="FlashButton"
                        Width="150"
                        Height="36"
                        Margin="0,5,0,0"
                        HorizontalAlignment="Left"
                        Style="{StaticResource RoundedButtonStyle}"
                        IsEnabled="False"
                        Click="FlashFirmware_Click">
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <md:PackIcon Kind="FlashCircle" 
                                     Width="18" 
                                     Height="18" 
                                     Margin="-10,0,6,0"/>
                        <TextBlock Text="Flash Firmware" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>